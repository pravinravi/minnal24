# Minnal24.com Environment Variables
# Copy this file to .env.local and fill in your values

# Site
NEXT_PUBLIC_SITE_URL=https://www.minnal24.com
NEXT_PUBLIC_SITE_NAME=Minnal24
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Social Media
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/minnal24
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/minnal24
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/minnal24news
NEXT_PUBLIC_WHATSAPP_NUMBER=94XXXXXXXXX

# Contact
NEXT_PUBLIC_CONTACT_EMAIL=news@minnal24.com
NEXT_PUBLIC_ADS_EMAIL=ads@minnal24.com
NEXT_PUBLIC_PHONE=+94XXXXXXXXX

# Optional: CMS API (if using headless CMS)
# CMS_API_URL=https://api.minnal24.com
# CMS_API_KEY=your_api_key_here

# Optional: Newsletter service
# MAILCHIMP_API_KEY=your_key
# MAILCHIMP_LIST_ID=your_list_id
